{
  "name": "4chan-yt-playlist",
  "metadata": {
    "name": "4chan - YouTube Playlist",
    "version": "3.0.0",
    "namespace": "4chan-yt-playlist",
    "description": "Wraps all YouTube videos inside a thread into a playlist",
    "include": [
      "https://boards.4chan.org/*/thread/*",
      "https://warosu.org/*/thread/*"
    ],
    "grant": [
      "GM_setValue",
      "GM_getValue"
    ],
    "run-at": "document-body"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/youtube": "^0.0.50",
    "@violentmonkey/types": "^0.1.7",
    "html-minifier-terser": "^7.2.0",
    "rollup": "^4.53.1",
    "rollup-plugin-string-import": "^1.2.6",
    "rollup-plugin-styler": "^2.0.0",
    "rollup-plugin-userscript-metablock": "^0.4.3",
    "sass": "^1.94.2",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5"
  },
  "type": "module",
  "scripts": {
    "build": "npx rollup -c"
  },
  "license": "ISC"
}
